{
  "name": "relay-manager",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "npx tsx set-env.ts && ng serve",
    "build": "npx tsx set-env.ts && ng build",
    "watch": "npx tsx set-env.ts && ng build --watch --configuration development",
    "test": "npx tsx set-env.ts && ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.1",
    "@angular/cli": "^21.0.1",
    "@angular/compiler-cli": "^21.0.0",
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2"
  }
}
